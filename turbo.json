{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "ACCESS_KEY",
    "SECRET_ACCESS_KEY",
    "BUCKET_REGION",
    "BUCKET_KEY",
    "BUCKET_NAME",
    "DISTRIBUTION_DOMAIN",
    "DISTRIBUTION_ID",
    "CLOUD_FRONT_KEYPAIR_ID",
    "CLOUD_FRONT_PRIVATE_KEY",
    "BOT_INTERNAL_TOKEN"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
